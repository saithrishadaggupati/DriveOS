<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDiagTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Diagnostics"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvDTCCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active DTCs: 0"
        android:textColor="@color/warning_red"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/tvDiagTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvDTCList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="No active fault codes"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvDTCCount"
        app:layout_constraintBottom_toTopOf="@id/btnClearDTCs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnClearDTCs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear DTCs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>