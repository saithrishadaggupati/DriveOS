<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvHvacTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HVAC Control"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvCabinTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cabin: --&#176;C"
        android:textColor="@color/accent_blue"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvHvacTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tvTargetTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Target: --&#176;C"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/tvCabinTemp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvFanSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fan: --"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/tvTargetTemp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvACStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A/C: OFF"
        android:textColor="@color/text_secondary"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/tvFanSpeed"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>