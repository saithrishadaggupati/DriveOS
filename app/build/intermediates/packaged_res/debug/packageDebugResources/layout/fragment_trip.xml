<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTripTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trip Computer"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvTripDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trip: -- km"
        android:textColor="@color/accent_blue"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/tvTripTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvAvgSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Avg Speed: -- km/h"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/tvTripDistance"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvFuelConsumed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fuel Used: -- L"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/tvAvgSpeed"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvAvgFuelEconomy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Economy: -- L/100km"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/tvFuelConsumed"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvTripDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Duration: 00:00:00"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/tvAvgFuelEconomy"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvOdometer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ODO: -- km"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvTripDuration"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
